{
  "permissions": {
    "allow": ["WebFetch(domain:raw.githubusercontent.com)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-flashcard-style.sh",
            "statusMessage": "플래시카드 문체 점검 중...",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
